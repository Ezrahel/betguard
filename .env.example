# Nomba API credentials (from your hackathon email)
NOMBA_PARENT_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_PRIVATE_KEY=
# Nomba API base URL (use sandbox for testing)
NOMBA_BASE_URL=https://sandbox.nomba.com

# Supabase project credentials
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# App config
PORT=3000
APP_URL=https://your-app-url.com

# Webhook secret (set this to any random string, register same value on Nomba dashboard)
WEBHOOK_SECRET=your_webhook_secret_here
